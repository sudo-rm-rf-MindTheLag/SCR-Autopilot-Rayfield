local rayfieldFontApplied = false

local function applyRayfieldMontserrat()
    if rayfieldFontApplied then
        return true
    end

    local player = game.Players.LocalPlayer
    if not player then
        return false
    end

    local playerGui = player:FindFirstChildOfClass("PlayerGui")
    if not playerGui then
        return false
    end

    local rayfieldGui
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and string.find(string.lower(gui.Name), "rayfield") then
            rayfieldGui = gui
            break
        end
    end

    if not rayfieldGui then
        return false
    end

    local function setTextFont(obj)
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            local ok = pcall(function()
                obj.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
            end)
            if not ok then
                obj.Font = Enum.Font.Gotham
            end
        end
    end

    for _, obj in ipairs(rayfieldGui:GetDescendants()) do
        setTextFont(obj)
    end
    rayfieldGui.DescendantAdded:Connect(setTextFont)
    rayfieldFontApplied = true
    return true
end

