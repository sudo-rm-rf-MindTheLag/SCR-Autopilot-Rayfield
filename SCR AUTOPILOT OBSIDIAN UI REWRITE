Toggles.EnableAutopilot:OnChanged(function()
    local enabled = Toggles.EnableAutopilot.Value
    if enabled then
        if Toggles.EnableAutoGuard.Value then
            Toggles.EnableAutoGuard:SetValue(false)
        end

        local started = autopilot:start()
        if not started then
            Toggles.EnableAutopilot:SetValue(false)
            Library:Notify("Autopilot failed to start.", 4)
        else
            Library:Notify("Autopilot enabled.", 2)
        end
    else
        autopilot:stop()
        Library:Notify("Autopilot disabled.", 2)
    end
end)

Toggles.AutoNextLeg:OnChanged(function()
    autoNextLegEnabled = Toggles.AutoNextLeg.Value
    if not autoNextLegEnabled then
        return
    end

    task.spawn(function()
        while autoNextLegEnabled do
            if autopilot.refs and autopilot.refs.nl and autopilot.refs.nl.Visible and autopilot.refs.nl.Active then
                if firesignal and autopilot.refs.nl.MouseButton1Click then
                    pcall(function()
                        firesignal(autopilot.refs.nl.MouseButton1Click)
                    end)
                else
                    pcall(function()
                        autopilot.refs.nl:Activate()
                    end)
                end
            end
            task.wait(1.5)
        end
    end)
end)

Toggles.EnableAutoGuard:OnChanged(function()
    autoGuardEnabled = Toggles.EnableAutoGuard.Value

    if autoGuardEnabled then
        if Toggles.EnableAutopilot.Value then
            Toggles.EnableAutopilot:SetValue(false)
        end

        if autoGuardRunning then
            return
        end

        autoGuardRunning = true
        Library:Notify("Auto Guard enabled.", 2)
        task.spawn(function()
            while autoGuardEnabled do
                pressKey(Enum.KeyCode.E)
                task.wait(0.1)
                pressKey(Enum.KeyCode.T)
                task.wait(0.1)
                pressKey(Enum.KeyCode.Y)
                task.wait(0.1)
                pressKey(Enum.KeyCode.Q)
                task.wait(0.1)
                pressKey(Enum.KeyCode.R)
                task.wait(0.1)
            end
            autoGuardRunning = false
        end)
    else
        Library:Notify("Auto Guard disabled.", 2)
    end
end)

Toggles.ObeySpeedLimit:OnChanged(function()
    settings.OBEYSPEEDLIMIT = Toggles.ObeySpeedLimit.Value
    autopilot:refresh()
end)

Options.MaxSpeed:OnChanged(function()
